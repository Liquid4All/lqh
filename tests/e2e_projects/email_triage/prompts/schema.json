{
  "type": "json_schema",
  "json_schema": {
    "name": "email_triage",
    "strict": true,
    "schema": {
      "type": "object",
      "properties": {
        "category": {
          "type": "string",
          "enum": [
            "billing",
            "shipping",
            "product_quality",
            "account",
            "feature_request",
            "other"
          ]
        },
        "priority": {
          "type": "string",
          "enum": ["p0", "p1", "p2", "p3"]
        },
        "next_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "acknowledge",
              "escalate",
              "offer_refund",
              "loop_in_team",
              "request_more_info",
              "close"
            ]
          },
          "minItems": 1,
          "maxItems": 3
        },
        "rationale": {
          "type": "string"
        }
      },
      "required": ["category", "priority", "next_actions", "rationale"],
      "additionalProperties": false
    }
  }
}
